10 PRINT "--- THE GUESSING GAME ---"
20 LET SECRET = INT(RND(1) * 100) + 1
30 LET GUESSES = 0
40 PRINT "I AM THINKING OF A NUMBER BETWEEN 1 AND 100."
50 PRINT "WHAT IS YOUR GUESS";
60 INPUT G
70 LET GUESSES = GUESSES + 1
80 IF G = SECRET THEN GOTO 130
90 IF G < SECRET THEN PRINT "TOO LOW!"
100 IF G > SECRET THEN PRINT "TOO HIGH!"
110 GOTO 50
130 PRINT "CORRECT! IT TOOK YOU"; GUESSES; "TRIES."
140 PRINT "PLAY AGAIN? (1=YES, 0=NO)"
150 INPUT A
160 IF A = 1 THEN GOTO 20
170 PRINT "THANKS FOR PLAYING!"
180 END
