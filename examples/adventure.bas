10 REM ============================================
20 REM  DUNGEON OF DOOM - A TEXT ADVENTURE GAME
30 REM  Written in Vibe BASIC
40 REM ============================================
50 PRINT "========================================="
60 PRINT "        DUNGEON OF DOOM"
70 PRINT "========================================="
80 PRINT
90 PRINT "YOU AWAKEN ON THE COLD STONE FLOOR OF A"
100 PRINT "DUNGEON. TORCHLIGHT FLICKERS ON THE WALLS."
110 PRINT "YOU MUST FIND YOUR WAY OUT ALIVE!"
120 PRINT
130 REM --- GAME STATE VARIABLES ---
140 ROOM = 1
150 HP = 10
160 HAS_KEY = 0
170 HAS_SWORD = 0
180 HAS_SHIELD = 0
190 DRAGON_ALIVE = 1
200 CHEST_OPEN = 0
210 PRINT "YOU HAVE"; HP; "HIT POINTS."
220 PRINT
230 REM ============================================
240 REM  MAIN GAME LOOP - DISPATCH BY ROOM
250 REM ============================================
260 IF ROOM = 1 THEN 1000
270 IF ROOM = 2 THEN 2000
280 IF ROOM = 3 THEN 3000
290 IF ROOM = 4 THEN 4000
300 IF ROOM = 5 THEN 5000
310 IF ROOM = 6 THEN 6000
320 IF ROOM = 7 THEN 7000
330 IF ROOM = 8 THEN 8000
340 PRINT "ERROR: UNKNOWN ROOM!"
350 END
900 REM ============================================
910 REM  STATUS DISPLAY
920 REM ============================================
930 PRINT
940 PRINT "--- STATUS: HP ="; HP;
950 IF HAS_SWORD = 1 THEN PRINT " | SWORD";
960 IF HAS_SHIELD = 1 THEN PRINT " | SHIELD";
970 IF HAS_KEY = 1 THEN PRINT " | KEY";
980 PRINT " ---"
990 GOTO 260
1000 REM ============================================
1010 REM  ROOM 1: THE CELL
1020 REM ============================================
1030 PRINT "--- THE CELL ---"
1040 PRINT "YOU ARE IN A SMALL DUNGEON CELL."
1050 PRINT "THE IRON DOOR IS RUSTED AND AJAR."
1060 IF HAS_SWORD = 0 THEN PRINT "A RUSTY SWORD LIES IN THE CORNER."
1070 PRINT
1080 PRINT "EXITS: (1) NORTH TO CORRIDOR"
1090 IF HAS_SWORD = 0 THEN PRINT "       (2) TAKE SWORD"
1100 INPUT "CHOICE: "; C
1110 IF C = 2 THEN IF HAS_SWORD = 0 THEN HAS_SWORD = 1 : PRINT "YOU PICK UP THE RUSTY SWORD." : GOTO 930
1120 IF C = 1 THEN ROOM = 2 : GOTO 930
1130 PRINT "YOU CAN'T DO THAT."
1140 GOTO 1000
2000 REM ============================================
2010 REM  ROOM 2: THE CORRIDOR
2020 REM ============================================
2030 PRINT "--- THE CORRIDOR ---"
2040 PRINT "A LONG STONE CORRIDOR STRETCHES BEFORE YOU."
2050 PRINT "TORCHES LINE THE WALLS. YOU HEAR DRIPPING"
2060 PRINT "WATER AND A FAINT GROWLING TO THE EAST."
2070 PRINT
2080 PRINT "EXITS: (1) SOUTH TO CELL"
2090 PRINT "       (2) NORTH TO GREAT HALL"
2100 PRINT "       (3) EAST TO GUARD ROOM"
2110 PRINT "       (4) WEST TO ARMORY"
2120 INPUT "CHOICE: "; C
2130 IF C = 1 THEN ROOM = 1 : GOTO 930
2140 IF C = 2 THEN ROOM = 4 : GOTO 930
2150 IF C = 3 THEN ROOM = 3 : GOTO 930
2160 IF C = 4 THEN ROOM = 5 : GOTO 930
2170 PRINT "YOU CAN'T DO THAT."
2180 GOTO 2000
3000 REM ============================================
3010 REM  ROOM 3: THE GUARD ROOM
3020 REM ============================================
3030 PRINT "--- THE GUARD ROOM ---"
3040 PRINT "THIS ROOM REEKS OF STALE ALE."
3050 PRINT "AN ORC GUARD SNORES AT A WOODEN TABLE."
3060 IF CHEST_OPEN = 0 THEN PRINT "A LOCKED CHEST SITS IN THE CORNER."
3070 IF CHEST_OPEN = 1 THEN PRINT "AN OPEN CHEST SITS IN THE CORNER."
3080 PRINT
3090 PRINT "EXITS: (1) WEST TO CORRIDOR"
3100 PRINT "       (2) SNEAK PAST ORC"
3110 PRINT "       (3) FIGHT ORC"
3120 IF CHEST_OPEN = 0 THEN IF HAS_KEY = 1 THEN PRINT "       (4) OPEN CHEST WITH KEY"
3130 INPUT "CHOICE: "; C
3140 IF C = 1 THEN ROOM = 2 : GOTO 930
3150 IF C = 2 THEN 3300
3160 IF C = 3 THEN 3400
3170 IF C = 4 THEN IF HAS_KEY = 1 THEN IF CHEST_OPEN = 0 THEN 3500
3180 PRINT "YOU CAN'T DO THAT."
3190 GOTO 3000
3300 REM --- SNEAK PAST ORC ---
3310 LET LUCK = INT(RND(1) * 10)
3320 IF LUCK < 5 THEN PRINT "THE ORC STIRS BUT DOESN'T WAKE. PHEW!" : GOTO 3000
3330 PRINT "THE ORC WAKES UP AND STRIKES YOU!"
3340 HP = HP - 3
3350 PRINT "YOU LOSE 3 HP!"
3360 IF HP <= 0 THEN 9000
3370 GOTO 3000
3400 REM --- FIGHT ORC ---
3410 IF HAS_SWORD = 0 THEN PRINT "YOU HAVE NO WEAPON! THE ORC LAUGHS." : HP = HP - 4 : PRINT "YOU LOSE 4 HP!" : IF HP <= 0 THEN 9000 ELSE GOTO 3000
3420 PRINT "YOU SWING YOUR SWORD AT THE ORC!"
3430 LET ROLL = INT(RND(1) * 10)
3440 IF HAS_SHIELD = 1 THEN ROLL = ROLL + 2
3450 IF ROLL >= 4 THEN PRINT "YOU SLAY THE ORC! WELL DONE!" : GOTO 3000
3460 PRINT "THE ORC BLOCKS YOUR ATTACK AND HITS BACK!"
3470 HP = HP - 2
3480 PRINT "YOU LOSE 2 HP! HP ="; HP
3490 IF HP <= 0 THEN 9000
3495 GOTO 3000
3500 REM --- OPEN CHEST ---
3510 CHEST_OPEN = 1
3520 PRINT "YOU UNLOCK THE CHEST WITH THE BRASS KEY."
3530 PRINT "INSIDE YOU FIND A HEALING POTION!"
3540 HP = HP + 5
3550 PRINT "YOU DRINK IT. HP RESTORED TO"; HP
3560 GOTO 3000
4000 REM ============================================
4010 REM  ROOM 4: THE GREAT HALL
4020 REM ============================================
4030 PRINT "--- THE GREAT HALL ---"
4040 PRINT "A VAST HALL WITH CRUMBLING PILLARS."
4050 PRINT "FADED TAPESTRIES HANG FROM THE WALLS."
4060 PRINT "MOONLIGHT STREAMS THROUGH A HIGH WINDOW."
4070 PRINT
4080 PRINT "EXITS: (1) SOUTH TO CORRIDOR"
4090 PRINT "       (2) EAST TO DRAGON'S LAIR"
4100 PRINT "       (3) WEST TO CHAPEL"
4110 INPUT "CHOICE: "; C
4120 IF C = 1 THEN ROOM = 2 : GOTO 930
4130 IF C = 2 THEN ROOM = 6 : GOTO 930
4140 IF C = 3 THEN ROOM = 7 : GOTO 930
4150 PRINT "YOU CAN'T DO THAT."
4160 GOTO 4000
5000 REM ============================================
5010 REM  ROOM 5: THE ARMORY
5020 REM ============================================
5030 PRINT "--- THE ARMORY ---"
5040 PRINT "WEAPON RACKS LINE THE WALLS, BUT MOST"
5050 PRINT "ARE EMPTY. COBWEBS COVER EVERYTHING."
5060 IF HAS_SHIELD = 0 THEN PRINT "A WOODEN SHIELD HANGS ON THE WALL."
5070 IF HAS_KEY = 0 THEN PRINT "A BRASS KEY GLINTS ON A HIGH SHELF."
5080 PRINT
5090 PRINT "EXITS: (1) EAST TO CORRIDOR"
5100 IF HAS_SHIELD = 0 THEN PRINT "       (2) TAKE SHIELD"
5110 IF HAS_KEY = 0 THEN PRINT "       (3) TAKE KEY"
5120 INPUT "CHOICE: "; C
5130 IF C = 1 THEN ROOM = 2 : GOTO 930
5140 IF C = 2 THEN IF HAS_SHIELD = 0 THEN HAS_SHIELD = 1 : PRINT "YOU TAKE THE WOODEN SHIELD." : GOTO 930
5150 IF C = 3 THEN IF HAS_KEY = 0 THEN HAS_KEY = 1 : PRINT "YOU GRAB THE BRASS KEY." : GOTO 930
5160 PRINT "YOU CAN'T DO THAT."
5170 GOTO 5000
6000 REM ============================================
6010 REM  ROOM 6: THE DRAGON'S LAIR
6020 REM ============================================
6030 PRINT "--- THE DRAGON'S LAIR ---"
6040 IF DRAGON_ALIVE = 0 THEN 6200
6050 PRINT "A MASSIVE RED DRAGON BLOCKS YOUR PATH!"
6060 PRINT "ITS EYES GLOW LIKE EMBERS. SMOKE CURLS"
6070 PRINT "FROM ITS NOSTRILS. BEHIND IT YOU SEE"
6080 PRINT "A HEAVY LOCKED OAK DOOR - THE EXIT!"
6090 PRINT
6100 PRINT "CHOICES: (1) FLEE WEST TO GREAT HALL"
6110 PRINT "         (2) FIGHT THE DRAGON"
6120 INPUT "CHOICE: "; C
6130 IF C = 1 THEN ROOM = 4 : GOTO 930
6140 IF C = 2 THEN 6300
6150 PRINT "YOU CAN'T DO THAT."
6160 GOTO 6000
6200 REM --- DRAGON IS DEAD ---
6210 PRINT "THE DRAGON'S CORPSE LIES SMOLDERING."
6220 PRINT "THE LOCKED EXIT DOOR IS AHEAD!"
6230 PRINT
6240 PRINT "CHOICES: (1) WEST TO GREAT HALL"
6245 IF HAS_KEY = 1 THEN PRINT "         (2) UNLOCK AND OPEN THE EXIT DOOR"
6246 IF HAS_KEY = 0 THEN PRINT "         THE DOOR IS LOCKED. YOU NEED A KEY."
6260 INPUT "CHOICE: "; C
6270 IF C = 1 THEN ROOM = 4 : GOTO 930
6280 IF C = 2 THEN IF HAS_KEY = 1 THEN ROOM = 8 : GOTO 930
6285 IF C = 2 THEN PRINT "THE DOOR WON'T BUDGE WITHOUT A KEY." : GOTO 6200
6290 GOTO 6200
6300 REM --- FIGHT THE DRAGON ---
6310 IF HAS_SWORD = 0 THEN PRINT "YOU HAVE NO WEAPON! THE DRAGON ROASTS YOU!" : GOTO 9000
6320 PRINT "YOU CHARGE AT THE DRAGON WITH YOUR SWORD!"
6330 LET ROLL = INT(RND(1) * 10)
6340 IF HAS_SHIELD = 1 THEN ROLL = ROLL + 3
6350 IF ROLL >= 7 THEN 6400
6360 PRINT "THE DRAGON BREATHES FIRE!"
6365 IF HAS_SHIELD = 1 THEN PRINT "YOUR SHIELD BLOCKS SOME OF THE FLAMES!"
6370 IF HAS_SHIELD = 1 THEN HP = HP - 2 ELSE HP = HP - 4
6380 PRINT "YOU LOSE HP! HP ="; HP
6390 IF HP <= 0 THEN 9000
6395 GOTO 6000
6400 REM --- DRAGON SLAIN ---
6410 PRINT "YOUR SWORD FINDS THE DRAGON'S WEAK SPOT!"
6420 PRINT "THE BEAST ROARS AND COLLAPSES!"
6430 PRINT "*** YOU HAVE SLAIN THE DRAGON! ***"
6440 DRAGON_ALIVE = 0
6450 GOTO 930
7000 REM ============================================
7010 REM  ROOM 7: THE CHAPEL
7020 REM ============================================
7030 PRINT "--- THE CHAPEL ---"
7040 PRINT "A SMALL CHAPEL WITH A STONE ALTAR."
7050 PRINT "STAINED GLASS CASTS COLORED LIGHT."
7060 PRINT "A SENSE OF PEACE FILLS THE ROOM."
7070 PRINT
7080 PRINT "EXITS: (1) EAST TO GREAT HALL"
7090 PRINT "       (2) PRAY AT THE ALTAR"
7100 INPUT "CHOICE: "; C
7110 IF C = 1 THEN ROOM = 4 : GOTO 930
7120 IF C = 2 THEN 7200
7130 PRINT "YOU CAN'T DO THAT."
7140 GOTO 7000
7200 REM --- PRAY ---
7210 LET BLESSING = INT(RND(1) * 3)
7220 IF BLESSING = 0 THEN PRINT "A WARM LIGHT SURROUNDS YOU." : HP = HP + 3 : PRINT "YOU FEEL HEALED! HP ="; HP
7230 IF BLESSING = 1 THEN PRINT "YOU FEEL A MOMENT OF CALM." : PRINT "NOTHING ELSE HAPPENS."
7240 IF BLESSING = 2 THEN PRINT "A VOICE WHISPERS: SEEK THE ARMORY." : PRINT "COURAGE FILLS YOUR HEART!"
7250 GOTO 930
8000 REM ============================================
8010 REM  ROOM 8: FREEDOM!
8020 REM ============================================
8030 PRINT
8040 PRINT "========================================="
8050 PRINT "  YOU PUSH OPEN THE HEAVY OAK DOOR..."
8060 PRINT "  COOL NIGHT AIR RUSHES OVER YOU."
8070 PRINT "  STARS GLITTER ABOVE THE FOREST."
8080 PRINT
8090 PRINT "  *** YOU HAVE ESCAPED THE DUNGEON! ***"
8100 PRINT
8110 PRINT "  FINAL HP:"; HP
8120 PRINT "========================================="
8130 PRINT
8140 PRINT "CONGRATULATIONS, BRAVE ADVENTURER!"
8150 PRINT "THANKS FOR PLAYING DUNGEON OF DOOM!"
8160 END
9000 REM ============================================
9010 REM  GAME OVER - DEATH
9020 REM ============================================
9030 PRINT
9040 PRINT "========================================="
9050 PRINT "  YOUR VISION FADES TO BLACK..."
9060 PRINT "  YOU HAVE PERISHED IN THE DUNGEON."
9070 PRINT
9080 PRINT "        *** GAME OVER ***"
9090 PRINT "========================================="
9100 PRINT
9110 PRINT "PLAY AGAIN? (1=YES, 0=NO)"
9120 INPUT C
9130 IF C = 1 THEN GOTO 140
9140 PRINT "FAREWELL, ADVENTURER."
9150 END
