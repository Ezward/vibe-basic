3260 IF C = 4 THEN IF ALICE_SIZE = 2 THEN ROOM = 6 : GOTO 530
3270 IF ALICE_SIZE <> 2 THEN IF C >= 2 THEN IF C <= 4 THEN PRINT "YOU MUST BE NORMAL SIZE TO EXPLORE!" : GOTO 3000
3280 PRINT "THAT MAKES NO SENSE."
