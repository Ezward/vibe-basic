3700 IF C = 2 THEN IF ALICE_SIZE = 3 THEN ALICE_SIZE = 2 : PRINT "YOU NIBBLE THE RIGHT PIECE..." : PRINT "YOU SHRINK BACK TO NORMAL SIZE!" : GOTO 530
3710 IF C = 2 THEN IF ALICE_SIZE = 1 THEN PRINT "YOU ARE ALREADY TOO SMALL!" : GOTO 3600
